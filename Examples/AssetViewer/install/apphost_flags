# DSAppHost configuration flags
# These values are read by CMake and used to generate install/apphost.json
# Lines starting with # are comments. Format: KEY=VALUE

APPHOST_PREVENT_SLEEP=true
APPHOST_KIOSK=true
APPHOST_RESTART_APPS=false
APPHOST_RESTART_APPS_HOUR=1
APPHOST_RESTART_APPS_MINUTE=0
APPHOST_RESTART_SYSTEM=true
APPHOST_RESTART_SYSTEM_HOUR=1
APPHOST_RESTART_SYSTEM_MINUTE=0
APPHOST_APP_ARGS=
APPHOST_START_DELAY=1000
APPHOST_RESTART_DELAY=10000
APPHOST_ENABLE_MONITOR=true
APPHOST_MEMORY_LIMIT=10000
