{
  "version": 6,
  "configurePresets": [
    {
      "name": "vcpkg-base",
      "hidden": true,
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
    },
    {
      "name": "qt",
      "hidden": false,
      "inherits": "vcpkg-base",
      "cacheVariables": {
        "CMAKE_INSTALL_PREFIX": "$env{USERPROFILE}/Documents/DsQt"
      }
    },
    {
      "name": "vs2022",
      "hidden": false,
      "displayName": "VS2022 x64 - Qt",
      "inherits": "qt",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/vs2022"
    },
    {
      "name": "ninja-base",
      "hidden": true,
      "generator": "Ninja Multi-Config",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "cl.exe",
        "CMAKE_CXX_COMPILER": "cl.exe",
        "CMAKE_CXX_FLAGS_INIT": "/EHsc",
        "CMAKE_CONFIGURATION_TYPES": "Debug;Release;RelWithDebInfo"
      }
    },
    {
      "name": "ninja",
      "hidden": false,
      "displayName": "Ninja - Qt",
      "inherits": ["qt", "ninja-base"],
      "binaryDir": "${sourceDir}/build/ninja"
    }
  ],
  "buildPresets": [
    {
      "name": "vs2022-debug",
      "displayName": "Debug",
      "configurePreset": "vs2022",
      "configuration": "Debug"
    },
    {
      "name": "vs2022-release",
      "displayName": "Release",
      "configurePreset": "vs2022",
      "configuration": "Release"
    },
    {
      "name": "vs2022-relwithdebinfo",
      "displayName": "RelWithDebInfo",
      "configurePreset": "vs2022",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "ninja-debug",
      "displayName": "Debug",
      "configurePreset": "ninja",
      "configuration": "Debug"
    },
    {
      "name": "ninja-release",
      "displayName": "Release",
      "configurePreset": "ninja",
      "configuration": "Release"
    },
    {
      "name": "ninja-relwithdebinfo",
      "displayName": "RelWithDebInfo",
      "configurePreset": "ninja",
      "configuration": "RelWithDebInfo"
    }
  ]
}
